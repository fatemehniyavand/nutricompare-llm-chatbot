# ==========================================================
# NutriCompare AI - Environment Variables
# ==========================================================

APP_NAME=NutriCompare AI
APP_ENV=development
DEBUG=true

# ----------------------------------------------------------
# Model A
# Example: OpenAI
# ----------------------------------------------------------
MODEL_A_PROVIDER=openai
MODEL_A_NAME=gpt-4o-mini
MODEL_A_API_KEY=your_openai_api_key_here
MODEL_A_BASE_URL=https://api.openai.com/v1

# ----------------------------------------------------------
# Model B
# Example: Groq OpenAI-compatible API
# ----------------------------------------------------------
MODEL_B_PROVIDER=groq
MODEL_B_NAME=llama-3.3-70b-versatile
MODEL_B_API_KEY=your_groq_api_key_here
MODEL_B_BASE_URL=https://api.groq.com/openai/v1

# ----------------------------------------------------------
# Judge Model
# Used to compare Model A and Model B
# ----------------------------------------------------------
JUDGE_MODEL_PROVIDER=openai
JUDGE_MODEL_NAME=gpt-4o-mini
JUDGE_MODEL_API_KEY=your_openai_api_key_here
JUDGE_MODEL_BASE_URL=https://api.openai.com/v1

# ----------------------------------------------------------
# Generation Settings
# ----------------------------------------------------------
DEFAULT_TEMPERATURE=0.2
JUDGE_TEMPERATURE=0.0
MAX_TOKENS=1200

# ----------------------------------------------------------
# Output
# ----------------------------------------------------------
EVALUATION_OUTPUT_PATH=eval/outputs/evaluation_results.csv
